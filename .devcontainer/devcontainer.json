{
  "name": "practice202603",
  "dockerComposeFile": ["compose.yaml", "compose.env.yaml"],
  "service": "workspace",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8080],
  "postCreateCommand": ".devcontainer/postCreate.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "charliermarsh.ruff",
        "ms-ossdata.vscode-pgsql",
        "ms-python.python",
        "oxc.oxc-vscode"
      ]
    },
    "settings": {
      "remote.autoForwardPorts": false,
      "remote.extensionKind": {
        "ms-ossdata.vscode-pgsql": ["workspace"]
      }
    }
  }
}
